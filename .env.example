# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_TEAM=price_...

# Upstash Redis
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# App
APP_ENV=development
FRONTEND_URL=http://localhost:5173
JWT_SECRET=your-secret-here
# Shared secret for /admin/* routes (manual invite / grant-access for
# promos, cash payments, etc.) — generate something random, set it only
# in Railway, never commit a real value here.
ADMIN_SECRET=

# AI providers (all optional — LLM router falls back across whichever
# of these are set; FASS FILL's regex parser works fully without any of them)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
# Order to try providers in, comma-separated. First with a key set + that succeeds wins.
LLM_PROVIDER_ORDER=anthropic,openai,gemini
